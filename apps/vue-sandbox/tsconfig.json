{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/components/ui/sapa-toast/*": ["../../registry/vue/ui/*"],
      "@/components/ui/*": ["../../registry/vue/ui/*"],
      "@/lib/*": ["../../registry/vue/lib/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "../../registry/vue/**/*.ts",
    "../../registry/vue/**/*.vue"
  ]
}
