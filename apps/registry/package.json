  "type": "module",
  "scripts": {
    "build:preview-css": "tailwindcss -i ./styles/preview-input.css -o ./public/toast-preview.css --minify",
    "prebuild": "node ../../scripts/build-registry.mjs && pnpm build:preview-css",
