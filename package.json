{
  "name": "sapa",
  "private": true,
  "version": "0.1.0",
  "description": "Sapa — your own cross-framework (React + Vue) component registry. v1: a custom-built, variated toast system.",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "registry:build": "node scripts/build-registry.mjs",
    "dev": "pnpm --filter registry dev",
    "build": "pnpm --filter registry build",
    "start": "pnpm --filter registry start",
    "sandbox": "pnpm --filter vue-sandbox dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck && pnpm typecheck:registry",
    "typecheck:registry": "tsc -p registry/react/tsconfig.json --noEmit && vue-tsc -p registry/vue/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{vue,css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "@lucide/vue": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.3.7"
  }
}
