{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "sapa",
  "homepage": "https://sapa.example.com",
  "items": [
    {
      "name": "theme",
      "type": "registry:style",
      "description": "Sapa design tokens (light/dark) incl. semantic toast rich colors + progress keyframes.",
      "dependencies": [
        "tailwindcss",
        "tw-animate-css"
      ],
      "cssVars": {
        "theme": {
          "--color-sapa-success": "var(--sapa-success)",
          "--color-sapa-success-foreground": "var(--sapa-success-foreground)",
          "--color-sapa-error": "var(--sapa-error)",
          "--color-sapa-error-foreground": "var(--sapa-error-foreground)",
          "--color-sapa-warning": "var(--sapa-warning)",
          "--color-sapa-warning-foreground": "var(--sapa-warning-foreground)",
          "--color-sapa-info": "var(--sapa-info)",
          "--color-sapa-info-foreground": "var(--sapa-info-foreground)"
        },
        "light": {
          "sapa-success": "oklch(0.62 0.17 149)",
          "sapa-success-foreground": "oklch(0.98 0.02 150)",
          "sapa-error": "oklch(0.58 0.22 27)",
          "sapa-error-foreground": "oklch(0.98 0.02 20)",
          "sapa-warning": "oklch(0.75 0.16 78)",
          "sapa-warning-foreground": "oklch(0.28 0.07 70)",
          "sapa-info": "oklch(0.6 0.13 240)",
          "sapa-info-foreground": "oklch(0.98 0.02 240)"
        },
        "dark": {
          "sapa-success": "oklch(0.7 0.16 150)",
          "sapa-success-foreground": "oklch(0.16 0.03 150)",
          "sapa-error": "oklch(0.7 0.19 22)",
          "sapa-error-foreground": "oklch(0.16 0.04 20)",
          "sapa-warning": "oklch(0.82 0.16 82)",
          "sapa-warning-foreground": "oklch(0.2 0.06 70)",
          "sapa-info": "oklch(0.68 0.14 240)",
          "sapa-info-foreground": "oklch(0.16 0.03 240)"
        }
      },
      "css": {
        "@keyframes sapa-toast-progress": {
          "from": {
            "transform": "scaleX(1)"
          },
          "to": {
            "transform": "scaleX(0)"
          }
        }
      }
    },
    {
      "name": "react/utils",
      "type": "registry:lib",
      "dependencies": [
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        {
          "path": "utils.ts",
          "type": "registry:lib",
          "src": "registry/react/lib/utils.ts"
        }
      ]
    },
    {
      "name": "react/toaster",
      "type": "registry:ui",
      "title": "Toaster (React)",
